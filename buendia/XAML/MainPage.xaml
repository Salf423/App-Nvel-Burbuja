<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccelerometerEssential.MainPage"
             BackgroundColor="Black">

    <Grid>
        <Border HorizontalOptions="Center" 
               VerticalOptions="Center" 
               WidthRequest="250" 
               HeightRequest="250"
               BackgroundColor="#000000"
               Stroke="#16022e"
               StrokeThickness="1"
               Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="125" />
            </Border.StrokeShape>
            
            <Grid>
                <BoxView WidthRequest="2" BackgroundColor="#200143" HorizontalOptions="Center" VerticalOptions="FillAndExpand" />
                <BoxView HeightRequest="2" BackgroundColor="#201d5d" VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                
                <Border HorizontalOptions="Center" VerticalOptions="Center" 
                       WidthRequest="60" HeightRequest="60" 
                       BackgroundColor="Transparent" 
                       Stroke="#16022e" StrokeThickness="1"
                       Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30" />
                    </Border.StrokeShape>
                </Border>

                <Border x:Name="miBurbuja"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       WidthRequest="50"
                       HeightRequest="50"
                       BackgroundColor="#040f4d"
                       Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                </Border>
            </Grid>
        </Border>
    </Grid>

</ContentPage>