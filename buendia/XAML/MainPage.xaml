<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccelerometerEssential.MainPage"
             BackgroundColor="Black">

    <Grid>
        <Frame HorizontalOptions="Center" 
               VerticalOptions="Center" 
               WidthRequest="250" 
               HeightRequest="250" 
               CornerRadius="125" 
               BackgroundColor="#000000"
               BorderColor="#16022e"
               HasShadow="False"
               Padding="0">
            
            <Grid>
                <BoxView WidthRequest="2" BackgroundColor="#200143" HorizontalOptions="Center" VerticalOptions="FillAndExpand" />
                <BoxView HeightRequest="2" BackgroundColor="#201d5d" VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                <Frame HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="60" HeightRequest="60" CornerRadius="30" BackgroundColor="Transparent" BorderColor="#16022e" HasShadow="False" Padding="0"/>

                <Frame x:Name="miBurbuja"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       WidthRequest="50"
                       HeightRequest="50"
                       CornerRadius="25"
                       BackgroundColor="#040f4d"
                       HasShadow="True"
                       Padding="0" />
            </Grid>
        </Frame>
    </Grid>

</ContentPage>