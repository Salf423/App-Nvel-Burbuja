<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccelerometerEssential.MainPage"
             BackgroundColor="#121212">

    <Grid>
        <!-- The main circular level body -->
        <Border HorizontalOptions="Center" 
               VerticalOptions="Center" 
               WidthRequest="250" 
               HeightRequest="250"
               BackgroundColor="#1E1E1E"
               Stroke="#3A3A3A"
               StrokeThickness="4"
               Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="125" />
            </Border.StrokeShape>
            
            <Grid>
                <!-- Crosshairs -->
                <BoxView WidthRequest="2" BackgroundColor="#3A3A3A" HorizontalOptions="Center" VerticalOptions="Fill" />
                <BoxView HeightRequest="2" BackgroundColor="#3A3A3A" VerticalOptions="Center" HorizontalOptions="Fill" />
                
                <!-- Center Target Circle -->
                <Border HorizontalOptions="Center" VerticalOptions="Center" 
                       WidthRequest="60" HeightRequest="60" 
                       BackgroundColor="Transparent" 
                       Stroke="#FF4081" StrokeThickness="2"
                       Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30" />
                    </Border.StrokeShape>
                </Border>

                <!-- The moving bubble -->
                <Border x:Name="miBurbuja"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       WidthRequest="50"
                       HeightRequest="50"
                       BackgroundColor="#00E5FF"
                       Stroke="Transparent"
                       Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#00E5FF" Offset="0,0" Radius="10" Opacity="0.8" />
                    </Border.Shadow>
                </Border>
            </Grid>
        </Border>
    </Grid>

</ContentPage>